  "commands": {
    "quickstart": {
      "label": "🚀 Setup completo (Docker)",
      "command": "docker compose up -d && python scripts/generate_synthetic_data.py --records 500000 && python scripts/load_to_postgres.py",
      "description": "Levanta todo y genera datos de una vez"
    },
    "generateData": {
      "label": "📊 Generar datos sintéticos",
      "command": "python scripts/generate_synthetic_data.py --records 500000 --output data/",
      "description": "Crea 500K+ registros realistas"
    },
    "loadPG": {
      "label": "💾 Cargar datos a PostgreSQL",
      "command": "python scripts/load_to_postgres.py --file data/fleetlogix_full.csv",
      "description": "Inserta CSV en base de datos"
    },
    "runETL": {
      "label": "☁️ Ejecutar ETL → Snowflake",
      "command": "python scripts/etl_to_snowflake.py --config config/etl.json",
      "description": "Migra datos a Snowflake DW"
    },
    "testAPI": {
      "label": "🔌 Probar API PostgREST",
      "command": "curl -s http://localhost:3000/vehicles?limit=5 | jq .",
      "description": "Verifica endpoint REST"
    },
    "launchDashboard": {
      "label": "📈 Lanzar Dashboard Streamlit",
      "command": "cd dashboard && streamlit run app.py --server.port 8501",
      "description": "Abre panel analítico"
    },
    "testAll": {
      "label": "✅ Test de integración",
      "command": "bash scripts/test_integration.sh",
      "description": "Ejecuta suite de verificaciones"
    },
    "viewLogs": {
      "label": "📋 Ver logs de servicios",
      "command": "docker compose logs -f",
      "description": "Muestra logs en tiempo real"
    },
    "stopAll": {
      "label": "🛑 Detener todos los servicios",
      "command": "docker compose down",
      "description": "Apaga contenedores"
    },
    "cleanAll": {
      "label": "🗑️ Limpiar todo (¡peligro!)",
      "command": "docker compose down -v && rm -rf data/",
      "description": "Borra volúmenes y datos"
    }
  },
