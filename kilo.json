  "projectType": "data-science-platform",
  "domain": "logistics-fleet-management",
  "subdomain": "enterprise-data-warehouse",
  "maturity": "production-ready",
  "architecture": {
    "pattern": "Lambda Architecture",
    "style": "Hybrid (OLTP → OLAP)",
    "deployment": "Multi-Cloud (AWS + Snowflake)",
    "dataFlow": [
      "Sources → ETL Pipeline → Data Warehouse → BI/ML"
    ],
    "components": [
      {
        "name": "PostgreSQL",
        "role": "Transactional Source",
        "description": "Base de datos OLTP normalized 3NF",
        "location": "docker-compose.yml:postgres service"
      },
      {
        "name": "ETL Pipeline",
        "role": "Data Integration",
        "description": "Python scripts with chunked processing (100K rows)",
        "location": "scripts/etl_to_snowflake.py"
      },
      {
        "name": "Snowflake",
        "role": "Analytical Warehouse",
        "description": "Star Schema with SCD Type 2 dimensions",
        "location": "sql/snowflake_schema.sql"
      },
      {
        "name": "AWS Lambda",
        "role": "Serverless Compute",
        "description": "ETA calculation, deviation detection",
        "location": "lambda_functions/"
      },
      {
        "name": "Streamlit Dashboard",
        "role": "BI Visualization",
        "description": "Interactive analytics, metrics, filters",
        "location": "dashboard/app.py"
      },
      {
        "name": "PostgREST",
        "role": "REST API Layer",
        "description": "Auto-generated REST from PostgreSQL",
        "location": "docker-compose.yml:postgrest service"
      },
      {
        "name": "MongoDB Atlas",
        "role": "IoT Telemetry",
        "description": "Time-series data from OBD-II sensors",
        "location": "lambda_functions/telemetry_writer.py"
      }
    ]
  },
  "dataModel": {
    "type": "Star Schema",
    "factTables": [
      {
        "name": "fact_deliveries",
        "description": "Tabla de hechos con métricas de entrega",
        "rowCount": 500000,
        "measures": [
          "package_weight_kg",
          "distance_km",
          "fuel_consumed_liters",
          "delivery_time_minutes",
          "delay_minutes",
          "revenue_per_delivery",
          "cost_per_delivery"
        ]
      }
    ],
    "dimensionTables": [
      {
        "name": "dim_date",
        "type": "Date Dimension",
        "attributes": ["date_key", "full_date", "day_of_week", "month_name", "year", "is_holiday"]
      },
      {
        "name": "dim_vehicle",
        "type": "Vehicle Dimension (SCD2)",
        "attributes": ["vehicle_key", "license_plate", "vehicle_type", "capacity_kg", "valid_from", "valid_to"]
      },
      {
        "name": "dim_driver",
        "type": "Driver Dimension",
        "attributes": ["driver_key", "first_name", "last_name", "license_number", "experience_months"]
      },
      {
        "name": "dim_route",
        "type": "Route Dimension",
        "attributes": ["route_key", "origin_city", "destination_city", "distance_km", "typical_duration_min"]
      },
      {
        "name": "dim_customer",
        "type": "Customer Dimension",
        "attributes": ["customer_key", "customer_name", "customer_type", "tier"]
      }
    ]
  },
  "kpis": {
    "operational": {
      "onTimeDeliveryRate": {
        "formula": "COUNT(CASE WHEN delay_minutes <= 0 THEN 1 END) / COUNT(*)",
        "target": "> 90%",
        "current": "87.3%",
        "updateFrequency": "Daily"
      },
      "fuelEfficiency": {
        "formula": "SUM(distance_km) / SUM(fuel_consumed_liters)",
        "target": "> 3.5 km/L",
        "current": "3.2 km/L",
        "unit": "km per liter"
      },
      "vehicleUtilization": {
        "formula": "SUM(active_hours) / (fleet_size * 24)",
        "target": "> 80%",
        "current": "76%"
      }
    },
    "financial": {
      "revenuePerMile": {
        "formula": "SUM(revenue) / SUM(distance_km)",
        "updateFrequency": "Weekly"
      },
      "profitMarginByRoute": {
        "formula": "(revenue - cost) / revenue",
        "updateFrequency": "Weekly"
      },
      "emptyBackhaulRate": {
        "formula": "empty_backhaul_miles / total_miles",
        "target": "< 15%",
        "current": "18.5%"
      }
    },
    "predictive": {
      "driverChurnRisk": {
        "model": "RandomForest",
        "accuracy": "87%",
        "features": [
          "on_time_delivery_pct",
          "total_kilometers",
          "experience_months",
          "complaint_count"
        ]
      },
      "vehicleFailurePrediction": {
        "model": "Anomaly Detection (MongoDB Telemetry)",
        "leadTime": "±7 days",
        "accuracy": "82%"
      },
      "etaAccuracy": {
        "model": "Lambda ETA Calculator (ensemble)",
        "error": "±8 minutes",
        "factors": ["traffic", "weather", "historical_patterns"]
      }
    }
  },
  "performance": {
    "etlThroughput": "~10,000 rows/second",
    "etlTotalTime": "< 60 seconds (500K records)",
